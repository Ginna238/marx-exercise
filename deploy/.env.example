# Marx-Exercise 部署环境变量
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=marx_exercise

# Spring Boot 后端配置
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password_here

# JWT 密钥（与 application.yaml 保持一致）
JWT_SECRET=your-jwt-secret-at-least-32-chars
